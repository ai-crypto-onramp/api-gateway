# HTTP port the gateway listens on
PORT=8080

# pino log level
LOG_LEVEL=info

# Environment name
NODE_ENV=production

# Base URL for identity-auth service
IDENTITY_AUTH_URL=http://identity-auth.internal:8080

# Base URL for onboarding-kyc service
KYC_URL=http://onboarding-kyc.internal:8080

# Base URL for pricing-quote service
PRICING_URL=http://pricing-quote.internal:8080

# Base URL for transaction-orchestrator
ORCHESTRATOR_URL=http://transaction-orchestrator.internal:8080

# Default token-bucket refill rate (RPS)
RATE_LIMIT_RPS=10

# Default token-bucket burst size
RATE_LIMIT_BURST=20

# Redis connection string for shared limiter
RATE_LIMIT_REDIS_URL=redis://rate-limit.internal:6379

# Expected JWT issuer claim
JWT_ISSUER=https://auth.example.com

# Identity-auth JWKS endpoint
JWKS_URL=https://auth.example.com/.well-known/jwks.json

# Expected JWT audience
JWT_AUDIENCE=onramp-sdk

# Header name for partner API keys
PARTNER_API_KEY_HEADER=X-API-Key

# Default timeout for downstream calls
DOWNSTREAM_TIMEOUT_MS=5000

# Error % to trip a downstream breaker
CIRCUIT_BREAKER_THRESHOLD=50

# Comma-separated allow-list
CORS_ALLOWED_ORIGINS=https://app.example.com

# OTLP collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.internal:4318

# Service name reported in traces
OTEL_SERVICE_NAME=api-gateway

# Toggle the /v1/graphql BFF endpoint
ENABLE_GRAPHQL=false

# Secret for signing outbound partner webhooks (from secrets manager)
WEBHOOK_SIGNING_SECRET=replace-me